# Agents Usage Dashboard Configuration
# Copy this file to config.yaml and fill in your credentials

# Refresh interval for fetching agent usage data
# Supports durations like: 30s, 5m, 1h, 24h
# Default: 5m
refresh_interval: 5m

# Server port for the dashboard web interface
# Default: 8777
server_port: 8777

# Provider authentication settings
# Configure at least one provider to fetch usage data
# Remove a provider section completely to disable it
providers:

  # ZAI provider configuration (API key-based auth)
  # Get your API key from: https://z.ai/manage-apikey/apikey-list
  # Format: id.secret (two parts separated by a dot)
  zai:
    enabled: true
    api_key: "${ZAI_API_KEY}"

  # Kimi provider configuration (cookie-based auth)
  # Requires the kimi-auth cookie from kimi.com
  kimi:
    enabled: true
    cookies:
      "kimi.com":
        "kimi-auth": "${KIMI_AUTH_TOKEN}"

  # Codex provider configuration (OAuth tokens)
  # Install Codex CLI and run: codex login
  # See docs/codex-oauth.md for detailed setup
  codex:
    enabled: true
    oauth:
      token_file: "${HOME}/.codex/auth.json"

  # Claude provider configuration (cookie-based auth)
  # ⚠️ Currently blocked by Cloudflare - may not work
  # Extract cookies from claude.ai after logging in
  # Remove this section to disable Claude
  claude:
    enabled: false
    cookies:
      "claude.ai":
        "sessionKey": "${CLAUDE_SESSION_KEY}"

# Environment Variables Setup:
# ---------------------------
# Create a .env file or export environment variables:
#
#   export ZAI_API_KEY="your-id.your-secret"
#   export KIMI_AUTH_TOKEN="your-kimi-auth-token"
#   export CLAUDE_SESSION_KEY="your-claude-session-key"
#
# Codex uses OAuth tokens from ~/.codex/auth.json (no env vars needed)
# Or use a .env file and load it with direnv or similar.

# Cookie Extraction Guide:
# -----------------------
# Cookie-based providers require extracting cookies from your browser.
#
# Chrome/Edge:
#   1. Log in to the service (kimi.com or claude.ai)
#   2. Open Developer Tools (F12)
#   3. Go to Application tab -> Cookies
#   4. Select the domain
#   5. Copy cookie values to config.yaml
#
# Firefox:
#   1. Log in to the service
#   2. Open Developer Tools (F12)
#   3. Go to Storage tab -> Cookies
#   4. Select the domain
#   5. Copy cookie values to config.yaml

# Security Notes:
# --------------
# 1. This file uses environment variable references (${VAR}) for sensitive values
# 2. Actual secrets are in .env file which should never be committed
# 3. config.yaml itself is safe to commit (only references, no real values)
# 4. Set file permissions: chmod 600 .env
# 5. At least one provider must be configured
# 6. Cookie-based providers require valid session cookies
# 7. All sensitive values must use environment variables (${VAR})
# 8. Server port must be between 1 and 65535
# 9. Refresh interval supports: s (seconds), m (minutes), h (hours)
# 10. Remove a provider section from config.yaml to disable it

# Minimal Configuration (ZAI only):
# ---------------------------------
# refresh_interval: 5m
# server_port: 8777
# providers:
#   zai:
#     enabled: true
#     api_key: "${ZAI_API_KEY}"

