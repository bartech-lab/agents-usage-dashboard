# Environment variables for agents-dashboard
# Copy this file to .env and fill in your credentials
# Quotes are optional - both KEY=value and KEY="value" work

# Z-AI API key (format: id.secret) — get from https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=

# Codex session token — extract from chatgpt.com cookies (__Secure-next-auth.session-token)
CODEX_SESSION_TOKEN=

# Kimi auth token — extract from kimi.com cookies (kimi-auth)
KIMI_AUTH_TOKEN=

# Claude session key — extract from claude.ai cookies (sessionKey)
CLAUDE_SESSION_KEY=

# Optional configuration (defaults shown)
# REFRESH_INTERVAL=300
# DEBUG=false
# TZ=Europe/Warsaw
