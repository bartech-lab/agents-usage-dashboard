# Environment variables for agents-dashboard
# Copy this file to .env and fill in your credentials

# ═══════════════════════════════════════════════════════════════
# Kimi (Cookie-based authentication)
# ═══════════════════════════════════════════════════════════════
# Extract from: kimi.com cookies → kimi-auth
KIMI_AUTH_TOKEN=

# ═══════════════════════════════════════════════════════════════
# Z-AI (API key authentication)
# ═══════════════════════════════════════════════════════════════
# Get from: https://z.ai/manage-apikey/apikey-list
# Format: id.secret
ZAI_API_KEY=

# ═══════════════════════════════════════════════════════════════
# Codex (OAuth tokens)
# ═══════════════════════════════════════════════════════════════
# No environment variables needed
# Install Codex CLI and run: codex login
# Tokens stored in: ~/.codex/auth.json
# See docs/codex-oauth.md for setup instructions

# ═══════════════════════════════════════════════════════════════
# Claude (Cookie-based authentication)
# ═══════════════════════════════════════════════════════════════
# ⚠️ Currently blocked by Cloudflare - disabled by default
# Extract from: claude.ai cookies → sessionKey
CLAUDE_SESSION_KEY=
